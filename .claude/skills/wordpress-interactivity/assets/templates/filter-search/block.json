{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "NAMESPACE/filter-search",
  "title": "Filter Search",
  "category": "widgets",
  "icon": "search",
  "description": "Live search with instant filtering results.",
  "supports": {
    "interactivity": true,
    "color": {
      "background": true,
      "text": true
    },
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "postType": {
      "type": "string",
      "default": "post"
    },
    "placeholder": {
      "type": "string",
      "default": "Search..."
    },
    "minChars": {
      "type": "number",
      "default": 3
    }
  },
  "viewScriptModule": "file:./view.js",
  "render": "file:./render.php"
}
