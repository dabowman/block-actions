{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "shop/product-card",
  "title": "Product Card",
  "category": "widgets",
  "icon": "products",
  "description": "Product card with add to cart functionality.",
  "supports": {
    "interactivity": true,
    "color": {
      "background": true,
      "text": true
    }
  },
  "attributes": {
    "productId": {
      "type": "number"
    },
    "productName": {
      "type": "string"
    },
    "productPrice": {
      "type": "number"
    },
    "productImage": {
      "type": "string"
    }
  },
  "viewScriptModule": "file:./view.js",
  "render": "file:./render.php"
}
