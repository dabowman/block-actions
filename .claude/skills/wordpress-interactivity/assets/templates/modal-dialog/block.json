{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "NAMESPACE/modal",
  "title": "Modal Dialog",
  "category": "widgets",
  "icon": "editor-expand",
  "description": "Accessible modal dialog with focus management.",
  "supports": {
    "interactivity": true,
    "color": {
      "background": true,
      "text": true
    }
  },
  "attributes": {
    "triggerText": {
      "type": "string",
      "default": "Open Modal"
    },
    "modalTitle": {
      "type": "string",
      "default": "Modal Title"
    }
  },
  "viewScriptModule": "file:./view.js",
  "render": "file:./render.php"
}
