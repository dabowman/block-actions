{
  "name": "block-actions",
  "version": "3.0.0",
  "description": "Lightweight JavaScript actions for WordPress core blocks",
  "main": "build/block-extensions.js",
  "scripts": {
    "build": "rm -rf build && NODE_ENV=production webpack --config webpack.config.js --mode production",
    "start": "webpack --config webpack.config.js --mode development --watch",
    "packages-update": "wp-scripts packages-update",
    "create-action": "node scripts/create-action.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:php": "wp-env run tests-cli --env-cwd=wp-content/plugins/block-actions vendor/bin/phpunit",
    "lint": "wp-scripts lint-js",
    "lint:fix": "wp-scripts lint-js --fix",
    "lint:php": "wp-env run cli --env-cwd=wp-content/plugins/block-actions vendor/bin/phpcs",
    "lint:php:fix": "wp-env run cli --env-cwd=wp-content/plugins/block-actions vendor/bin/phpcbf",
    "zip": "mkdir -p dist && rm -f dist/block-actions.zip && zip -r dist/block-actions.zip block-actions.php uninstall.php readme.txt includes build patterns assets README.md docs -x 'docs/plans/*'",
    "env": "wp-env",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:restart": "wp-env start --update",
    "env:destroy": "wp-env destroy",
    "env:clean": "wp-env clean all",
    "env:logs": "wp-env logs",
    "env:cli": "wp-env run cli wp"
  },
  "author": "dabowman",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@babel/preset-env": "^7.22.5",
    "@babel/preset-react": "^7.22.5",
    "@testing-library/jest-dom": "^5.16.5",
    "@wordpress/scripts": "^31.6.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0"
  },
  "dependencies": {
    "@wordpress/block-editor": "^15.14.0",
    "@wordpress/blocks": "^15.14.0",
    "@wordpress/components": "^32.3.0",
    "@wordpress/compose": "^7.41.0",
    "@wordpress/data": "^10.41.0",
    "@wordpress/element": "^6.41.0",
    "@wordpress/hooks": "^4.41.0",
    "@wordpress/i18n": "^6.14.0",
    "@wordpress/interactivity": "^6.41.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "transform": {
      "^.+\\.[t|j]sx?$": "babel-jest"
    },
    "testMatch": [
      "<rootDir>/tests/**/*.test.js",
      "<rootDir>/tests/**/test-*.js"
    ],
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "<rootDir>/tests/__mocks__/styleMock.js",
      "@wordpress/interactivity-router$": "<rootDir>/tests/__mocks__/interactivity-router.js",
      "@wordpress/interactivity$": "<rootDir>/tests/__mocks__/interactivity.js",
      "@wordpress/plugins$": "<rootDir>/tests/__mocks__/wp-plugins.js",
      "@wordpress/editor$": "<rootDir>/tests/__mocks__/wp-editor.js"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/build/"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/**/*.test.{js,jsx}",
      "!src/index.js"
    ]
  },
  "browserslist": [
    "extends @wordpress/browserslist-config"
  ]
}
