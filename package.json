{
  "name": "block-actions",
  "version": "2.0.0",
  "description": "Lightweight JavaScript actions for WordPress core blocks",
  "main": "build/block-extensions.js",
  "scripts": {
    "build": "NODE_ENV=production webpack --config webpack.config.js --mode production",
    "start": "webpack --config webpack.config.js --mode development --watch",
    "packages-update": "wp-scripts packages-update",
    "create-action": "node scripts/create-action.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "zip": "git ls-files -z | xargs -0 -I{} sh -c 'mkdir -p dist && rm -f dist/block-actions.zip && zip -r dist/block-actions.zip block-actions.php build README.md docs || true'"
  },
  "author": "dabowman",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@babel/preset-env": "^7.22.5",
    "@babel/preset-react": "^7.22.5",
    "@testing-library/jest-dom": "^5.16.5",
    "@wordpress/scripts": "^26.19.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0"
  },
  "dependencies": {
    "@wordpress/api-fetch": "7.18.0",
    "@wordpress/block-editor": "^12.15.0",
    "@wordpress/blocks": "^12.24.0",
    "@wordpress/components": "^25.13.0",
    "@wordpress/compose": "^6.24.0",
    "@wordpress/element": "^5.24.0",
    "@wordpress/hooks": "^3.47.0",
    "@wordpress/interactivity": "^6.20.0",
    "dompurify": "^3.0.5",
    "lodash": "^4.17.21"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "transform": {
      "^.+\\.[t|j]sx?$": "babel-jest"
    },
    "testMatch": [
      "<rootDir>/tests/**/*.test.js",
      "<rootDir>/tests/**/test-*.js"
    ],
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "<rootDir>/tests/__mocks__/styleMock.js",
      "@wordpress/interactivity": "<rootDir>/tests/__mocks__/interactivity.js"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/build/"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/**/*.test.{js,jsx}",
      "!src/index.js"
    ]
  }
}
